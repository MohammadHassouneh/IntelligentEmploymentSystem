@model IntelligentEmploymentSystem.Models.LoginModel
@{
    ViewData["Title"] = "Login";

}

<style>
    .gradient-text {
        background: linear-gradient(90deg, #4285f4, #34a853);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
    }

    .gradient-bg {
        background: linear-gradient(90deg, #4285f4, #34a853);
        color: white;
    }

    .gradient-border {
        border: 1px solid transparent;
        background: linear-gradient(white, white), linear-gradient(90deg, #4285f4, #34a853);
        background-origin: border-box;
        background-clip: content-box, border-box;
    }
</style>

<div class="container d-flex align-items-center justify-content-center" style="min-height: 100vh;">
    <div class="card shadow-sm p-5" style="max-width: 400px; width: 100%; background-color: white; border: none; border-radius: 20px;">
        <!-- رمز المستخدم -->
        <div class="text-center mb-4">
            <div class="gradient-bg" style="width: 80px; height: 80px; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; margin-bottom: 15px;">
                <i class="fas fa-user-lock" style="font-size: 30px; color: white;"></i>
            </div>
            <h3 class="gradient-text" style="font-weight: normal; margin-top: 10px;">User Login</h3>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                Please fix the errors below.
            </div>
        }

        <form asp-action="Login" method="post">
            <!-- حقل اسم المستخدم -->
            <div class="mb-4">
                <div class="gradient-border" style="border-radius: 50px; padding: 5px;">
                    <div class="input-group">
                        <span class="input-group-text gradient-text" style="background: transparent; border: none;">
                            <i class="fas fa-user"></i>
                        </span>
                        <input asp-for="UserName" class="form-control" style="border: none; box-shadow: none; border-radius: 50px;" placeholder="Username" />
                    </div>
                </div>
                <span asp-validation-for="UserName" class="text-danger small d-block mt-2 ps-3"></span>
            </div>

            <!-- حقل كلمة المرور -->
            <div class="mb-4">
                <div class="gradient-border" style="border-radius: 50px; padding: 5px;">
                    <div class="input-group">
                        <span class="input-group-text gradient-text" style="background: transparent; border: none;">
                            <i class="fas fa-lock"></i>
                        </span>
                        <input asp-for="Password" type="password" class="form-control" style="border: none; box-shadow: none; border-radius: 50px;" placeholder="Password" />
                    </div>
                </div>
                <span asp-validation-for="Password" class="text-danger small d-block mt-2 ps-3"></span>
            </div>

            <!-- زر الدخول -->
            <div class="d-grid mb-3">
                <button type="submit" class="btn gradient-bg" style="padding: 12px; font-weight: bold; border: none; border-radius: 50px;">
                    <i class="fas fa-sign-in-alt"></i> LOGIN
                </button>
            </div>

            <!-- رابط التسجيل -->
            <div class="text-center">
                <a asp-action="Create" asp-controller="User" class="gradient-text" style="text-decoration: none; font-weight: bold;">Don't have an account? Register now</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/js/all.min.js"></script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}