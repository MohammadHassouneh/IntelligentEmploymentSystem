@model IntelligentEmploymentSystem.Models.LoginModel
@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container d-flex align-items-center justify-content-center" style="min-height: 100vh;">
    <div class="login-card shadow p-5 rounded-4 bg-white" style="max-width: 450px; width: 100%;">
        <h2 class="text-center text-primary mb-4">
            <i class="fas fa-user-lock"></i> Login
        </h2>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                Please fix the errors below.
            </div>
        }

        <form asp-action="Login" method="post">
            <div class="mb-3">
                <label asp-for="UserName" class="form-label"><i class="fas fa-user"></i> Username</label>
                <input asp-for="UserName" class="form-control" placeholder="Enter your username" />
                <span asp-validation-for="UserName" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label"><i class="fas fa-lock"></i> Password</label>
                <input asp-for="Password" type="password" class="form-control" placeholder="********" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="d-grid">
                <button type="submit" class="btn btn-primary btn-lg">
                    <i class="fas fa-sign-in-alt"></i> Login
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/js/all.min.js"></script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}


