@model IntelligentEmploymentSystem.Models.ProfileModel

@{
    ViewData["Title"] = "Profile";
}

<style>
    /* تدرج لوني للأزرار */
    .btn-gradient {
        background: linear-gradient(90deg, #0d6efd, #20c997); /* أزرق إلى أخضر */
        border: none;
        color: white;
        transition: background 0.3s ease;
    }

        .btn-gradient:hover {
            background: linear-gradient(90deg, #20c997, #0d6efd);
            color: white;
        }

    .btn-outline-gradient {
        border: 2px solid #0d6efd;
        color: #0d6efd;
        background: transparent;
        transition: all 0.3s ease;
    }

        .btn-outline-gradient:hover {
            background: linear-gradient(90deg, #0d6efd, #20c997);
            color: white;
            border-color: transparent;
        }
</style>

<div class="container py-5" style="max-width: 700px;">
    <!-- ترحيب متدرج -->
    <h1 style="
        font-weight: 900;
        font-size: 3rem;
        background: linear-gradient(BLACK);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin-bottom: 2rem;
        text-align: center;
        letter-spacing: 3px;
    ">
        WELCOME @Model.User.UserName.ToUpper()

    </h1>

    <!-- معلومات الحساب -->
    <div class="card mb-4 shadow-sm rounded-3">
        <div class="card-body text-center">
            <h4 class="mb-3">@Model.User.UserName</h4>
            <p class="mb-2"><strong>Email:</strong> @Model.User.Email</p>
            <a asp-action="GetAllJobDescription" asp-controller="JobDescription" class="btn btn-gradient mt-3 px-4">
                Apply for Jobs
            </a>
            <a asp-action="Logout" class="btn btn-outline-gradient mt-3 ms-2 px-4">
                Logout
            </a>
        </div>
    </div>

    <!-- السيرة الذاتية -->
    <div class="card shadow-sm rounded-3">
        <div class="card-body">
            @if (Model.Resume != null)
            {
                <h5 class="mb-4 text-center">Your Resume</h5>
                <div class="text-center mb-4">
                    <img src="@Model.Resume.PicPath" alt="Resume Image" class="img-fluid rounded-3 shadow" style="max-height: 300px;">
                </div>
                <p><strong>Name:</strong> @Model.Resume.Name</p>
                <p><strong>Summary:</strong> @Model.Resume.Summary</p>
                <p><strong>Skills:</strong> @Model.Resume.Skills</p>
                <p><strong>Education:</strong> @Model.Resume.Education</p>
                <p><strong>Experience:</strong> @Model.Resume.Experience</p>
                <div class="text-center mt-4">
                    <a asp-action="Update" asp-controller="Resume" class="btn btn-gradient px-4">Update Resume</a>
                </div>
            }
            else
            {
                <p class="text-center">No resume found.</p>
                <div class="text-center">
                    <a asp-action="Create" asp-controller="Resume" class="btn btn-outline-gradient px-4">Create one now</a>
                </div>
            }
        </div>
    </div>
</div>

