@model IEnumerable<IntelligentEmploymentSystem.Models.JobDescriptionModel>
@{
    ViewData["Title"] = "Home Page";
    ViewData["IsHomePage"] = true;
}

<!-- Hero Section -->
<section class="hero-section py-5 mb-5">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 order-lg-1 order-2">
                <h1 class="hero-title display-4 fw-bold">
                    <span class="gradient-text">Explore Your Future Career</span>
                </h1>
                <p class="hero-subtitle lead text-muted">
                    Connecting talents with the right opportunities through intelligence and innovation.
                </p>
                <div class="hero-cta mt-4">
                    <a href="#jobs" class="btn btn-primary btn-lg px-4">Browse Jobs</a>
                </div>
            </div>
            <div class="col-lg-6 order-lg-2 order-1 text-center mb-4 mb-lg-0">
                <img src="~/images/home-career.jpg" alt="Career" class="img-fluid rounded" style="max-height: 350px; box-shadow: 0 10px 30px rgba(0,0,0,0.1);">
            </div>
        </div>
    </div>
</section>

<!-- Job Cards Section -->
<section class="job-section py-5 bg-light" id="jobs">
    <div class="container">
        <div class="section-header text-center mb-5">
            <h2 class="section-title">
                <span class="gradient-text">Available Job Opportunities</span>
            </h2>
            <p class="section-subtitle text-muted">Find your perfect match from our curated listings</p>
        </div>

        <div class="row g-4">
            @foreach (var job in Model)
            {
                <div class="col-lg-4 col-md-6">
                    <div class="card h-100 border-0 shadow-sm job-card">
                        <div class="card-body d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <h3 class="card-title fw-bold gradient-text">@job.JobTitle</h3>
                                <span class="badge bg-primary bg-opacity-10 text-primary">Featured</span>
                            </div>
                            <h6 class="card-subtitle mb-3 text-muted">
                                <i class="fas fa-building me-2"></i>@job.CompanyName
                            </h6>
                            <p class="card-text text-dark flex-grow-1">@job.JobBrief</p>
                            <div class="mt-auto pt-3">
                                <a class="btn btn-outline-primary w-100" asp-controller="JobDescription" asp-action="GetAllJobDescription">
                                    Apply Now <i class="fas fa-arrow-right ms-2"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<style>
    /* Base Styles */
    body {
        background-color: #fff;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    /* Gradient Text */
    .gradient-text {
        background: linear-gradient(135deg, #007bff, #28a745);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        display: inline;
    }

    /* Hero Section */
    .hero-section {
        background-color: #fff;
    }

    .hero-title {
        line-height: 1.2;
        margin-bottom: 1.5rem;
    }

    .hero-subtitle {
        max-width: 500px;
    }

    /* Job Cards */
    .job-card {
        transition: all 0.3s ease;
        border-radius: 12px;
        overflow: hidden;
    }

        .job-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        }

    .card-title {
        font-size: 1.25rem;
    }

    .card-subtitle {
        font-size: 0.9rem;
    }

    .card-text {
        font-size: 0.95rem;
        line-height: 1.6;
    }

    /* Section Styling */
    .section-title {
        font-size: 2rem;
        margin-bottom: 0.5rem;
    }

    .section-subtitle {
        font-size: 1.1rem;
    }

    /* Buttons */
    .btn-primary {
        background: linear-gradient(135deg, #007bff, #28a745);
        border: none;
        padding: 0.5rem 1.75rem;
    }

    .btn-outline-primary {
        border-color: #007bff;
        color: #007bff;
        transition: all 0.3s ease;
    }

        .btn-outline-primary:hover {
            background: #007bff;
            color: #fff;
        }

    /* Responsive Adjustments */
    @@media (max-width: 768px) {
        .hero-title {
            font-size: 2.2rem;
        }

        .section-title {
            font-size: 1.75rem;
        }
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        // Animate job cards on load
        const cards = document.querySelectorAll('.job-card');
        cards.forEach((card, index) => {
            card.style.opacity = '0';
            card.style.transform = 'translateY(20px)';

            setTimeout(() => {
                card.style.transition = 'all 0.5s ease-out';
                card.style.opacity = '1';
                card.style.transform = 'translateY(0)';
            }, index * 100);
        });

        // Add hover effect to buttons
        const buttons = document.querySelectorAll('.btn');
        buttons.forEach(btn => {
            btn.addEventListener('mouseenter', () => {
                btn.style.transform = 'translateY(-2px)';
            });
            btn.addEventListener('mouseleave', () => {
                btn.style.transform = 'translateY(0)';
            });
        });
    });
</script>




