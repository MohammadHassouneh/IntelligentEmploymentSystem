@model IntelligentEmploymentSystem.Models.CompanyLoginModel

@{
    ViewData["Title"] = "Company Login";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container d-flex align-items-center justify-content-center" style="min-height: 100vh;">
    <div class="card shadow-lg p-5 rounded-4" style="max-width: 500px; width: 100%; background: linear-gradient(to bottom right, #e0f7fa, #ffffff);">
        <h2 class="text-center text-primary mb-4"><i class="fas fa-building"></i> Company Login</h2>

        <form asp-action="Login" method="post">
            <div class="mb-3">
                <label asp-for="Email" class="form-label"><i class="fas fa-envelope"></i> Email <span class="text-danger">*</span></label>
                <input asp-for="Email" class="form-control" placeholder="Enter company email" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label"><i class="fas fa-lock"></i> Password <span class="text-danger">*</span></label>
                <input asp-for="Password" type="password" class="form-control" placeholder="Enter password" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            @Html.ValidationSummary(false, "", new { @class = "text-danger" })

            <div class="d-grid">
                <button type="submit" class="btn btn-primary btn-lg">
                    <i class="fas fa-sign-in-alt"></i> Login
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/js/all.min.js"></script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}






















