@model IntelligentEmploymentSystem.Models.CompanyModel
@{
    ViewData["Title"] = "Company Profile";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>@Model.CompanyName - Profile</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
        body {
            background-color: #f8f9fa;
        }

        .company-header {
            background-color: #0d6efd;
            color: white;
            padding: 30px;
            border-radius: 10px;
        }

        .card-title {
            color: #0d6efd;
        }
    </style>
</head>
<body>

    <div class="container py-5">

        <!-- Header -->
        <div class="company-header text-center mb-5">
            <h1 class="display-5 fw-bold">@Model.CompanyName</h1>
            <p class="lead">Company Profile</p>
        </div>

        <!-- About & Service -->
        <div class="row g-4 mb-4">
            <div class="col-md-6">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title"><i class="bi bi-info-circle"></i> About Us</h5>
                        <p class="card-text">@Model.AboutUs</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title"><i class="bi bi-briefcase-fill"></i> Our Services</h5>
                        <p class="card-text">@Model.OurService</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Contact Info -->
        <div class="row g-4 mb-4">
            <div class="col-md-3">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h6><i class="bi bi-telephone-fill"></i> Phone</h6>
                        <p class="mb-0">@Model.Phone</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h6><i class="bi bi-envelope-fill"></i> Email</h6>
                        <p class="mb-0">@Model.Email</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h6><i class="bi bi-geo-alt-fill"></i> Address</h6>
                        <p class="mb-0">@Model.Address</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h6><i class="bi bi-globe"></i> Website</h6>
                        <p class="mb-0">@Model.WebSite</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Actions -->
        <div class="row g-3 mb-3">
            <div class="col-md-4">
                @using (Html.BeginForm("Create", "JobDescription", FormMethod.Post))
                {
                    <button class="btn btn-primary w-100"><i class="bi bi-plus-circle"></i> Post Jobs</button>
                }
            </div>
            <div class="col-md-4">
                @using (Html.BeginForm("Update", "Company", FormMethod.Get))
                {
                    <button class="btn btn-warning w-100"><i class="bi bi-pencil-square"></i> Update Profile</button>
                }
            </div>
            <div class="col-md-4">
                @using (Html.BeginForm("Logout", "Company", FormMethod.Post))
                {
                    <button class="btn btn-outline-danger w-100"><i class="bi bi-box-arrow-right"></i> Logout</button>
                }
            </div>
        </div>

        <div class="row g-3">
            <div class="col-md-4">
                @using (Html.BeginForm("JobReview", "Company", FormMethod.Post))
                {
                    <button class="btn btn-success w-100"><i class="bi bi-journal-text"></i> Job Reviews</button>
                }
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>








