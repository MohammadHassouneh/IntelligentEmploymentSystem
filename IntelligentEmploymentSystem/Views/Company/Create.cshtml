@model IntelligentEmploymentSystem.Models.CompanyModel
@{
    ViewData["Title"] = "Company Registration";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    :root {
        --primary-blue: #4285f4;
        --primary-green: #34a853;
        --gradient: linear-gradient(90deg, var(--primary-blue), var(--primary-green));
        --light-gray: #f8f9fa;
        --dark-text: #2d3748;
        --medium-text: #4a5568;
    }

    body {
        background-color: var(--light-gray);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .gradient-text {
        background: var(--gradient);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        font-weight: 700;
    }

    .registration-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        padding: 2rem;
    }

    .registration-card {
        width: 100%;
        max-width: 700px;
        background-color: white;
        border-radius: 20px;
        padding: 2.5rem;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
        transition: transform 0.3s ease;
    }

        .registration-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.12);
        }

    .form-header {
        text-align: center;
        margin-bottom: 2.5rem;
    }

        .form-header i {
            font-size: 1.8rem;
            margin-right: 0.8rem;
            vertical-align: middle;
        }

    .form-section {
        margin-bottom: 2rem;
    }

    .section-title {
        font-size: 1.2rem;
        font-weight: 600;
        margin-bottom: 1.5rem;
        position: relative;
        padding-bottom: 0.5rem;
    }

        .section-title:after {
            content: '';
            position: absolute;
            left: 0;
            bottom: 0;
            width: 50px;
            height: 3px;
            background: var(--gradient);
            border-radius: 3px;
        }

    .form-group {
        margin-bottom: 1.5rem;
        position: relative;
    }

    .form-label {
        display: block;
        margin-bottom: 0.5rem;
        font-weight: 500;
        color: var(--dark-text);
    }

    .required-star {
        color: #dc3545;
        margin-left: 3px;
    }

    .input-container {
        position: relative;
        border-radius: 10px;
        background: linear-gradient(white, white) padding-box, var(--gradient) border-box;
        border: 2px solid transparent;
        transition: all 0.3s ease;
    }

        .input-container:hover {
            box-shadow: 0 0 0 4px rgba(66, 133, 244, 0.1);
        }

    .form-control {
        border: none;
        background: transparent;
        padding: 0.9rem 1.2rem;
        width: 100%;
        font-size: 1rem;
        color: var(--dark-text);
        transition: all 0.3s ease;
    }

        .form-control:focus {
            outline: none;
            box-shadow: none;
        }

        .form-control::placeholder {
            color: #a0aec0;
            opacity: 1;
        }

    textarea.form-control {
        min-height: 120px;
        resize: vertical;
    }

    .validation-message {
        font-size: 0.85rem;
        margin-top: 0.5rem;
        color: #dc3545;
        display: block;
    }

    .submit-btn {
        background: var(--gradient);
        color: white;
        border: none;
        border-radius: 50px;
        padding: 1rem;
        font-size: 1.1rem;
        font-weight: 600;
        width: 100%;
        transition: all 0.3s ease;
        margin-top: 1rem;
        box-shadow: 0 4px 15px rgba(66, 133, 244, 0.3);
    }

        .submit-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(66, 133, 244, 0.4);
        }

        .submit-btn i {
            margin-right: 0.8rem;
        }

    @@media (max-width: 768px) {
        .registration-container {
            padding: 1rem;
        }

        .registration-card {
            padding: 1.5rem;
        }

        .form-header {
            margin-bottom: 1.5rem;
        }

        .section-title {
            font-size: 1.1rem;
        }
    }
</style>

<div class="registration-container">
    <div class="registration-card">
        <div class="form-header">
            <h2 class="gradient-text">
                <i class="fas fa-building"></i> Company Registration
            </h2>
            <p class="text-muted">Complete your company profile to get started</p>
        </div>

        <form asp-action="Registration" method="post">
            <!-- Company Information -->
            <div class="form-section">
                <h3 class="section-title gradient-text">Company Information</h3>

                <div class="form-group">
                    <label asp-for="CompanyName" class="form-label">
                        Company Name <span class="required-star">*</span>
                    </label>
                    <div class="input-container">
                        <input asp-for="CompanyName" class="form-control" placeholder="Enter your company name" />
                    </div>
                    <span asp-validation-for="CompanyName" class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Email" class="form-label">
                        Email <span class="required-star">*</span>
                    </label>
                    <div class="input-container">
                        <input asp-for="Email" class="form-control" placeholder="Enter company email address" />
                    </div>
                    <span asp-validation-for="Email" class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Password" class="form-label">
                        Password <span class="required-star">*</span>
                    </label>
                    <div class="input-container">
                        <input asp-for="Password" type="password" class="form-control" placeholder="Create a secure password" />
                    </div>
                    <span asp-validation-for="Password" class="validation-message"></span>
                </div>
            </div>

            <!-- About Sections -->
            <div class="form-section">
                <h3 class="section-title gradient-text">About the Company</h3>

                <div class="form-group">
                    <label asp-for="AboutUs" class="form-label">
                        About Us <span class="required-star">*</span>
                    </label>
                    <div class="input-container">
                        <textarea asp-for="AboutUs" class="form-control" rows="4"
                                  placeholder="Describe your company's mission, values, and history"></textarea>
                    </div>
                    <span asp-validation-for="AboutUs" class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label asp-for="OurService" class="form-label">
                        Our Services <span class="required-star">*</span>
                    </label>
                    <div class="input-container">
                        <textarea asp-for="OurService" class="form-control" rows="4"
                                  placeholder="Describe the products or services your company offers"></textarea>
                    </div>
                    <span asp-validation-for="OurService" class="validation-message"></span>
                </div>
            </div>

            <!-- Contact Information -->
            <div class="form-section">
                <h3 class="section-title gradient-text">Contact Information</h3>

                <div class="form-group">
                    <label asp-for="Phone" class="form-label">
                        Phone <span class="required-star">*</span>
                    </label>
                    <div class="input-container">
                        <input asp-for="Phone" class="form-control" placeholder="Enter company phone number" />
                    </div>
                    <span asp-validation-for="Phone" class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label asp-for="WebSite" class="form-label">
                        Website <span class="required-star">*</span>
                    </label>
                    <div class="input-container">
                        <input asp-for="WebSite" class="form-control" placeholder="Enter company website URL" />
                    </div>
                    <span asp-validation-for="WebSite" class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Address" class="form-label">
                        Address <span class="required-star">*</span>
                    </label>
                    <div class="input-container">
                        <input asp-for="Address" class="form-control" placeholder="Enter company physical address" />
                    </div>
                    <span asp-validation-for="Address" class="validation-message"></span>
                </div>
            </div>

            <!-- Submit Button -->
            <button type="submit" class="submit-btn">
                <i class="fas fa-user-plus"></i> REGISTER COMPANY
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/js/all.min.js"></script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // Enhance form interactions
        document.addEventListener("DOMContentLoaded", function() {
            const inputContainers = document.querySelectorAll('.input-container');

            inputContainers.forEach(container => {
                const input = container.querySelector('.form-control');

                // Add focus effect
                input.addEventListener('focus', () => {
                    container.style.boxShadow = '0 0 0 4px rgba(66, 133, 244, 0.2)';
                });

                // Remove focus effect
                input.addEventListener('blur', () => {
                    container.style.boxShadow = '';
                });
            });
        });
    </script>
}