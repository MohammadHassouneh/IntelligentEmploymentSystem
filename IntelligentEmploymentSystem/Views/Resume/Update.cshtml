@model IntelligentEmploymentSystem.Models.ResumeModel

@{
    ViewBag.Title = "Update Resume";  // تعريف عنوان الصفحة
    Layout = "~/Views/Shared/_Layout.cshtml";  // تحديد Layout مشترك (غالباً هذا السطر يكون ضمن _ViewStart.cshtml)
}

@section Styles {
    <!-- هنا تضيف CSS خاص بالصفحة -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />
    <style>
        .form-wrapper {
            max-width: 700px;
            margin: 30px auto;
            background: #fff;
            padding: 30px 35px;
            border-radius: 15px;
            box-shadow: 0 8px 20px rgba(0,0,0,0.12);
            border: 1px solid #ddd;
        }

        h2 {
            text-align: center;
            font-weight: 700;
            margin-bottom: 25px;
            color: #0d6efd;
            letter-spacing: 1.5px;
        }

        form .row {
            display: flex;
            gap: 20px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }

        form .col-6 {
            flex: 1 1 48%;
            position: relative;
        }

        label {
            font-weight: 600;
            margin-bottom: 8px;
            display: block;
            font-size: 1.05rem;
            color: #333;
        }

        .input-icon {
            position: relative;
            display: flex;
            align-items: center;
        }

            .input-icon i {
                position: absolute;
                left: 12px;
                color: #0d6efd;
                font-size: 1.2rem;
                pointer-events: none;
            }

        input[type="text"],
        input[type="email"],
        textarea,
        input[type="file"] {
            width: 100%;
            padding: 12px 15px 12px 40px;
            font-size: 1rem;
            border: 2px solid #ccc;
            border-radius: 10px;
            transition: all 0.3s ease;
            font-family: inherit;
        }

            input[type="text"]:focus,
            input[type="email"]:focus,
            textarea:focus,
            input[type="file"]:focus {
                outline: none;
                border-color: #0d6efd;
                box-shadow: 0 0 8px rgba(13,110,253,0.35);
            }

        textarea {
            resize: vertical;
            min-height: 100px;
            padding-left: 15px;
        }

        .text-danger {
            font-size: 0.85rem;
            color: #dc3545;
            margin-top: -14px;
            margin-bottom: 14px;
            font-weight: 600;
        }

        .btn-primary {
            display: block;
            width: 100%;
            padding: 14px 0;
            font-size: 1.15rem;
            font-weight: 700;
            color: #fff;
            background: linear-gradient(90deg, #0d6efd, #0056b3);
            border: none;
            border-radius: 12px;
            cursor: pointer;
            box-shadow: 0 5px 15px rgba(13, 110, 253, 0.4);
            transition: background 0.3s ease, box-shadow 0.3s ease;
            margin-top: 10px;
        }

            .btn-primary:hover {
                background: linear-gradient(90deg, #0056b3, #0d47a1);
                box-shadow: 0 8px 20px rgba(13, 71, 161, 0.6);
            }

        .btn-info {
            display: inline-block;
            padding: 10px 22px;
            background: #17a2b8;
            color: #fff;
            border-radius: 10px;
            text-decoration: none;
            font-weight: 600;
            font-size: 1rem;
            box-shadow: 0 3px 12px rgba(23,162,184,0.4);
            transition: background 0.3s ease, box-shadow 0.3s ease;
            margin-top: -8px;
            margin-bottom: 22px;
        }

            .btn-info:hover {
                background: #117a8b;
                box-shadow: 0 5px 18px rgba(17, 122, 139, 0.6);
                text-decoration: none;
                color: #fff;
            }
    </style>
}

<div class="form-wrapper">
    <h2>Update Your Resume</h2>
    <form asp-action="Update" method="post" enctype="multipart/form-data" novalidate>
        <div class="row">
            <div class="col-6">
                <label asp-for="Name">Name <span class="text-danger">*</span></label>
                <div class="input-icon">
                    <i class="bi bi-person-fill"></i>
                    <input type="text" asp-for="Name" />
                </div>
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="col-6">
                <label asp-for="Phone">Phone <span class="text-danger">*</span></label>
                <div class="input-icon">
                    <i class="bi bi-telephone-fill"></i>
                    <input type="text" asp-for="Phone" />
                </div>
                <span asp-validation-for="Phone" class="text-danger"></span>
            </div>
        </div>

        <div class="row">
            <div class="col-6">
                <label asp-for="Email">Email <span class="text-danger">*</span></label>
                <div class="input-icon">
                    <i class="bi bi-envelope-fill"></i>
                    <input type="email" asp-for="Email" />
                </div>
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="col-6">
                <label asp-for="Address">Address <span class="text-danger">*</span></label>
                <div class="input-icon">
                    <i class="bi bi-geo-alt-fill"></i>
                    <input type="text" asp-for="Address" />
                </div>
                <span asp-validation-for="Address" class="text-danger"></span>
            </div>
        </div>

        <div class="row">
            <div class="col-6">
                <label asp-for="Summary">Summary <span class="text-danger">*</span></label>
                <textarea asp-for="Summary"></textarea>
                <span asp-validation-for="Summary" class="text-danger"></span>
            </div>
            <div class="col-6">
                <label asp-for="Experience">Experience <span class="text-danger">*</span></label>
                <textarea asp-for="Experience"></textarea>
                <span asp-validation-for="Experience" class="text-danger"></span>
            </div>
        </div>

        <div class="row">
            <div class="col-6">
                <label asp-for="Skills">Skills <span class="text-danger">*</span></label>
                <textarea asp-for="Skills"></textarea>
                <span asp-validation-for="Skills" class="text-danger"></span>
            </div>
            <div class="col-6">
                <label asp-for="Education">Education <span class="text-danger">*</span></label>
                <textarea asp-for="Education"></textarea>
                <span asp-validation-for="Education" class="text-danger"></span>
            </div>
        </div>

        <div class="row">
            <div class="col-6">
                <label for="formFile">Upload Your Picture</label>
                <input asp-for="PicPath" type="file" />
            </div>

            @if (Model.ImagePath != null)
            {
                <div class="col-6" style="display:flex; align-items:center; padding-top: 30px;">
                    <a href="@Model.ImagePath" target="_blank" class="btn-info">Show Current Image</a>
                </div>
            }
        </div>

        <button type="submit" class="btn-primary">Update Resume</button>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}






