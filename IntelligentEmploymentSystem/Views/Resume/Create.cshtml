@{
}
@model IntelligentEmploymentSystem.Models.ResumeModel;

<html>
<head>

</head>
<body>
    <form asp-action="AddResume" enctype="multipart/form-data">
        <dev class="row">
            <dev class="col-md-4">
               Name
                <span class="text-danger">*</span>
                <input type="text" class="form-control" asp-for="Name" />
                <span asp-validation-for="Name" class="text-danger"></span>

            </dev>           

        </dev>

        <dev class="row">
            <dev class="col-md-4">
                Summary
                <span class="text-danger">*</span>
                <textarea class="form-control " rows="5" asp-for="Summary"></textarea>
                <span asp-validation-for="Summary" class="text-danger"></span>
            </dev>

        </dev>
        <dev class="row">
            <dev class="col-md-4">
                Experience
                <span class="text-danger">*</span>
                <textarea class="form-control " rows="5" asp-for="Experience"></textarea>
                <span asp-validation-for="Experience" class="text-danger"></span>
            </dev>
            <dev class="col-md-4">
                Skills
                <span class="text-danger">*</span>
                <textarea class="form-control " rows="5" asp-for="Skills"></textarea>
                <span asp-validation-for="Skills" class="text-danger"></span>
            </dev>

        </dev>
        <dev class="row">
            <dev class="col-md-4">
                Education
                <span class="text-danger">*</span>
                <textarea class="form-control " rows="5" asp-for="Education"></textarea>
                <span asp-validation-for="Education" class="text-danger"></span>
            </dev>

        </dev>
        
        <dev class="row">
            <dev class="col-md-4">
                Phone
                <span class="text-danger">*</span>
                <input type="text" class="form-control" asp-for="Phone" />
                <span asp-validation-for="Phone" class="text-danger"></span>

            </dev>
            <dev class="col-md-4">
                Email
                <span class="text-danger">*</span>
                <input type="text" class="form-control " asp-for="Email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </dev>
            <dev class="col-md-4">
                Address
                <span class="text-danger">*</span>
                <input type="text" class="form-control " asp-for="Address" />
                <span asp-validation-for="Address" class="text-danger"></span>
            </dev>

        </dev>
        <dev class="row">

            <div class="col-md-4">
                <label for="formFile" class="form-label">Upload Your Picture</label>
                <input class="form-control" type="file" asp-for="PicPath">
            </div>
        </dev>
        

        <dev class="row" style="padding-top:10px">
            <div class="col-md-4">
                <input type="submit" class="btn btn-primary" value="Add Resume" />
            </div>

            
        </dev>
    </form>
</body>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
</html>