@model IntelligentEmploymentSystem.Models.JobDescriptionModel;

<div class="container py-5">
    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-body p-5 bg-white">
            <h2 class="text-center mb-4 fw-bold" style="
                background: linear-gradient(to right, #0d6efd, #20c997);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
            ">
                ✨ Add New Job Description
            </h2>

            <form asp-action="AddJobDescription">
                <div class="row mb-4">
                    <div class="col-md-12">
                        <label class="form-label fw-semibold">Job Title <span class="text-danger">*</span></label>
                        <input type="text" class="form-control rounded-pill" asp-for="JobTitle" placeholder="e.g. Software Engineer" />
                        <span asp-validation-for="JobTitle" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Job Brief <span class="text-danger">*</span></label>
                        <textarea class="form-control rounded-3" rows="5" asp-for="JobBrief" placeholder="Enter job brief..."></textarea>
                        <span asp-validation-for="JobBrief" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Responsibilities <span class="text-danger">*</span></label>
                        <textarea class="form-control rounded-3" rows="5" asp-for="Responsibilities" placeholder="Enter responsibilities..."></textarea>
                        <span asp-validation-for="Responsibilities" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col-md-12">
                        <label class="form-label fw-semibold">Requirements <span class="text-danger">*</span></label>
                        <textarea class="form-control rounded-3" rows="5" asp-for="Requirements" placeholder="Enter requirements..."></textarea>
                        <span asp-validation-for="Requirements" class="text-danger small"></span>
                    </div>
                </div>

                <div class="text-center">
                    <button type="submit" class="btn btn-success btn-lg px-5 rounded-pill">
                        <i class="bi bi-check-circle me-2"></i> Post Job Description
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

