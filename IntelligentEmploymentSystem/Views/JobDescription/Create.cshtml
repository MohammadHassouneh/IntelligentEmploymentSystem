@{
}
@model IntelligentEmploymentSystem.Models.JobDescriptionModel;

<html>
    <head>

    </head>

    <body>

    <form asp-action="AddJobDescription">
        <dev class="row">
            <dev class="col-md-4">
                Job Title
                <span class="text-danger">*</span>
                <input type="text" class="form-control" asp-for="JobTitle" />
                <span asp-validation-for="JobTitle" class="text-danger"></span>
            </dev>
            
        </dev>

        <dev class="row">
            <dev class="col-md-4">
                JobBrief
                <span class="text-danger">*</span>
                <textarea type="text" class="form-control" rows="8" asp-for="JobBrief"></textarea>
                <span asp-validation-for="JobBrief" class="text-danger"></span>
            </dev>
            <dev class="col-md-4">
                Responsibilities
                <span class="text-danger">*</span>
                <textarea type="text" class="form-control" rows="8" asp-for="Responsibilities"></textarea>
                <span asp-validation-for="Responsibilities" class="text-danger"></span>
            </dev>
            </dev>

            <dev class="row">
                <dev class="col-md-4">
                    Requirements
                    <span class="text-danger">*</span>
                    <textarea type="text" class="form-control" rows="8" asp-for="Requirements"></textarea>
                    <span asp-validation-for="Requirements" class="text-danger"></span>
                </dev>
               
                </dev>


       

        

        <dev class="row" style="padding-top:10px">
            <dev class="col-md-4">
                    <input type="submit" class="btn btn-primary" value="Post Job Description" />
            </dev>
        </dev>

    </form>






    </body>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

</html>

