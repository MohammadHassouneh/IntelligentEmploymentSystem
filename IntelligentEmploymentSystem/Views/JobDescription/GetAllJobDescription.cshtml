@model List<IntelligentEmploymentSystem.Models.JobDescriptionModel>

@{
    ViewBag.Title = "Available Jobs";
    ViewData["IsAvailableJobsPage"] = true;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container pt-4">
    <h1 class="text-center text-white mb-4">Available Job Opportunities</h1>

    <!-- Filters Section -->
    <div class="row g-2 align-items-end bg-white rounded p-3 mb-4 shadow">
        <div class="col-md-5">
            <label for="titleFilter" class="form-label fw-bold">فلترة حسب المسمى الوظيفي</label>
            <input type="text" id="titleFilter" class="form-control" placeholder="مثلاً: مهندس برمجيات">
        </div>
        <div class="col-md-5">
            <label for="companyFilter" class="form-label fw-bold">فلترة حسب اسم الشركة</label>
            <input type="text" id="companyFilter" class="form-control" placeholder="مثلاً: Google">
        </div>
        <div class="col-md-2 d-grid">
            <button class="btn btn-primary" onclick="applyFilters()">
                <i class="fas fa-filter me-1"></i> تطبيق الفلاتر
            </button>
        </div>
    </div>

    <!-- Job Cards -->
    <div class="row g-4">
        @foreach (var job in Model)
        {
            <div class="col-md-4 job-card">
                <div class="card card-job h-100 shadow-sm border-0">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title text-primary">@job.JobTitle</h5>
                        <h6 class="card-subtitle mb-2 text-muted">@job.CompanyName</h6>
                        <p class="card-text"><strong>Brief:</strong> @job.JobBrief?.Substring(0, Math.Min(100, job.JobBrief.Length))...</p>

                        <div class="mt-auto">
                            <button class="btn btn-outline-primary btn-sm w-100 mb-2" data-bs-toggle="modal" data-bs-target="#jobModal-@job.JobDescriptionId">
                                <i class="fas fa-info-circle me-1"></i> View Details
                            </button>

                            @if (job.Status == "Apply Now")
                            {
                                <a class="btn btn-success btn-sm w-100 mb-2" asp-action="Apply" asp-controller="Score" asp-route-jobId="@job.JobDescriptionId">
                                    <i class="fas fa-paper-plane me-1"></i> Apply
                                </a>

                                <button class="btn btn-info btn-sm w-100" onclick="getMatchScore(@job.JobDescriptionId)">
                                    <i class="fas fa-chart-line me-1"></i> Match Score
                                </button>

                                <div class="score-box text-primary mt-2" id="score-box-@job.JobDescriptionId"></div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function applyFilters() {
            let title = document.getElementById("titleFilter").value.toLowerCase();
            let company = document.getElementById("companyFilter").value.toLowerCase();
            let cards = document.querySelectorAll(".job-card");

            cards.forEach(card => {
                let titleText = card.querySelector(".card-title").innerText.toLowerCase();
                let companyText = card.querySelector(".card-subtitle").innerText.toLowerCase();

                if ((title === "" || titleText.includes(title)) &&
                    (company === "" || companyText.includes(company))) {
                    card.style.display = "block";
                } else {
                    card.style.display = "none";
                }
            });
        }

        function getMatchScore(jobId) {
            // هنا يمكنك إضافة منطق جلب وتحديث النتيجة حسب الوظيفة
            let box = document.getElementById("score-box-" + jobId);
            box.innerText = "Your match score is: " + (Math.random() * 100).toFixed(2) + "%";
        }
    </script>
}
